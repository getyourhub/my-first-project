# OpenAI API Key (required for OpenAI translator)
OPENAI_API_KEY=your_openai_api_key_here

# Xiaomi MiMo API Key (required for MiMo translator)
MIMO_API_KEY=your_mimo_api_key_here

# Xiaomi MiMo Token Plan Key (required for MiMo Token Plan translator)
MIMO_TOKEN_PLAN_KEY=your_mimo_token_plan_key_here

# Google Translate doesn't require API key for basic usage